<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_cars">

    <fragment
        android:id="@+id/nav_cars"
        android:name="com.example.carbyer.ui.CarsFragment"
        android:label="Cars">

        <action
            android:id="@+id/action_cars_to_edit"
            app:destination="@id/nav_car_create_update" />

        <action
            android:id="@+id/action_cars_to_create"
            app:destination="@id/nav_car_create_update" />
    </fragment>

    <fragment
        android:id="@+id/nav_car_create_update"
        android:name="com.example.carbyer.ui.CarsCreateUpdateFragment"
        android:label="Car" >
        <argument
            android:name="mode"
            app:argType="string"
            android:defaultValue="edit" />
    </fragment>

</navigation>